---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import OfficerCard from '../components/OfficerCard.astro';
import { Image } from 'astro:assets';
import protestCrowd from '../assets/images/protest-crowd.jpg';
import bannerGroup from '../assets/images/banner-group.jpg';
import { STATE_PARTY } from '../consts';

const officers = (await getCollection('officers')).sort((a, b) => a.data.order - b.data.order);
---

<Layout
  title="About Us"
  description="Learn about Columbia County Democrats' mission and the volunteer leadership team driving it."
>
  <section class="hero">
    <Image src={bannerGroup} alt="Columbia County Democrats volunteers holding the club banner" class="hero-img" width={1600} height={1200} />
    <div class="hero-overlay"></div>
    <div class="container hero-content">
      <p class="eyebrow" style="color: var(--color-gold-400);">Who we are</p>
      <h1>Democracy is not a spectator sport.</h1>
      <p class="lede">
        Columbia County Democrats is committed to fostering a vibrant democratic community here at
        home — upholding the U.S. Constitution, engaging every neighbor, and electing Democratic
        candidates who fight inequality and systemic racism head-on.
      </p>
    </div>
  </section>

  <Section background="white">
    <div class="mission-grid">
      <Image src={protestCrowd} alt="Columbia County Democrats members at a community protest" width={700} height={470} class="mission-img" />
      <div>
        <h2>Our mission</h2>
        <p>
          Columbia County Democrats is dedicated to upholding the U.S. Constitution and the
          principles that define our democracy. We believe in unity and inclusion, and in a shared
          commitment to justice and equality for everyone in our community — a commitment that
          matters more than ever as inequality and systemic racism continue to hold too many of
          our neighbors back.
        </p>
        <p>
          That means showing up: at the ballot box, at the county fair, at the food bank, and in
          the streets. We provide the resources, the community, and the organizing muscle — you
          bring your voice.
        </p>
        <p class="affiliation">
          We're the official Columbia County chapter of the{' '}
          <a href={STATE_PARTY.about} target="_blank" rel="noopener noreferrer">Oregon Democratic Party</a>,
          listed on their{' '}
          <a href={STATE_PARTY.county} target="_blank" rel="noopener noreferrer">county chapter page</a>.
        </p>
      </div>
    </div>
  </Section>

  <Section background="soft">
    <p class="eyebrow">Meet the team</p>
    <h2>Volunteer leadership, elected by the committee</h2>
    <div class="officers-grid">
      {officers.map((officer) => (
        <OfficerCard
          name={officer.data.name}
          role={officer.data.role}
          phone={officer.data.phone}
          photo={officer.data.photo}
        />
      ))}
    </div>
  </Section>
</Layout>

<style>
  .hero {
    position: relative;
    min-height: 26rem;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, rgba(10, 26, 51, 0.6) 0%, rgba(10, 26, 51, 0.92) 70%);
  }

  .hero-content {
    position: relative;
    color: white;
    max-width: 42rem;
    padding-block: 3.5rem;
    text-shadow: 0 2px 16px rgba(10, 26, 51, 0.5);
  }

  .hero-content h1 {
    color: white;
  }

  .lede {
    max-width: 48rem;
    font-size: 1.15rem;
    color: rgba(255, 255, 255, 0.85);
  }

  .mission-grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 3rem;
    align-items: center;
  }

  .affiliation {
    font-size: 0.9rem;
    color: var(--color-ink-soft);
  }

  .affiliation a {
    color: var(--color-blue-600);
    font-weight: 600;
  }

  .mission-img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
  }

  .officers-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-top: 2.5rem;
    max-width: 50rem;
  }

  @media (max-width: 900px) {
    .mission-grid,
    .officers-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

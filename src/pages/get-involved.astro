---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import DemoForm from '../components/DemoForm.astro';
import SocialCTAButtons from '../components/SocialCTAButtons.astro';
import { Image } from 'astro:assets';
import sunsetMeetingPlace from '../assets/images/sunset-meeting-place.jpg';
---

<Layout
  title="Get Involved"
  description="Volunteer with Columbia County Democrats or sign up for our newsletter."
>
  <section class="hero">
    <Image src={sunsetMeetingPlace} alt="A dramatic sunset sky over the hall where Columbia County Democrats meet" class="hero-img" width={1920} height={950} position="bottom" />
    <div class="hero-overlay"></div>
    <div class="container hero-content">
      <p class="eyebrow" style="color: var(--color-gold-400);">Democracy needs you</p>
      <h1>Get Involved</h1>
      <p class="lede">
        Whether you have five hours a week or five minutes a month, there's a place for you here.
      </p>
    </div>
  </section>

  <Section background="white">
    <div class="forms-grid">
      <div>
        <h2>Volunteer with us</h2>
        <p>
          Tell us a bit about yourself and how you'd like to help — canvassing, phone banking,
          hosting yard signs, or lending a professional skill.
        </p>
        <DemoForm id="volunteer-form" submitLabel="Sign Up to Volunteer">
          <div>
            <label for="v-name">Full name</label>
            <input id="v-name" name="name" type="text" required autocomplete="name" />
          </div>
          <div>
            <label for="v-email">Email</label>
            <input id="v-email" name="email" type="email" required autocomplete="email" />
          </div>
          <div>
            <label for="v-phone">Phone (optional)</label>
            <input id="v-phone" name="phone" type="tel" autocomplete="tel" />
          </div>
          <div>
            <label for="v-interest">How would you like to help?</label>
            <select id="v-interest" name="interest" required>
              <option value="">Choose one</option>
              <option value="canvassing">Canvassing / door-knocking</option>
              <option value="phonebanking">Phone banking</option>
              <option value="events">Event support</option>
              <option value="yard-sign">Host a yard sign</option>
              <option value="skills">Donate a professional skill</option>
              <option value="other">Something else</option>
            </select>
          </div>
          <div>
            <label for="v-message">Anything else we should know? (optional)</label>
            <textarea id="v-message" name="message" rows="3"></textarea>
          </div>
        </DemoForm>
      </div>

      <div>
        <h2>Join our newsletter</h2>
        <p>
          Get monthly meeting reminders, action alerts, and election updates straight to your
          inbox.
        </p>
        <DemoForm id="newsletter-form" submitLabel="Subscribe">
          <div>
            <label for="n-name">First name</label>
            <input id="n-name" name="name" type="text" required autocomplete="given-name" />
          </div>
          <div>
            <label for="n-email">Email</label>
            <input id="n-email" name="email" type="email" required autocomplete="email" />
          </div>
        </DemoForm>

        <div class="callout">
          <h3>Prefer to just show up?</h3>
          <p>Check our <a href="/events">Events page</a> for the next meeting or protest — no signup required.</p>
        </div>
      </div>
    </div>
  </Section>

  <Section background="gold">
    <div class="social-section">
      <div>
        <p class="eyebrow">The lowest-effort way to help</p>
        <h2>Just hit follow.</h2>
        <p>
          No form, no signup — following us on social is the easiest way to get involved. It's how
          we announce meeting times, protest locations, and last-minute action alerts first.
        </p>
      </div>
      <SocialCTAButtons />
    </div>
  </Section>
</Layout>

<style>
  .hero {
    position: relative;
    min-height: 32rem;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 65%;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(100deg, rgba(10, 26, 51, 0.75) 25%, rgba(10, 26, 51, 0.4) 80%);
  }

  .hero-content {
    position: relative;
    color: white;
    max-width: 42rem;
    padding-block: 3.5rem;
    text-shadow: 0 2px 16px rgba(10, 26, 51, 0.5);
  }

  .hero-content h1 {
    color: white;
  }

  .lede {
    color: rgba(255, 255, 255, 0.85);
    font-size: 1.1rem;
  }

  .forms-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 3.5rem;
  }

  .callout {
    margin-top: 2rem;
    background: var(--color-paper-soft);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
  }

  .callout h3 {
    margin-bottom: 0.5rem;
  }

  .social-section {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 2.5rem;
    align-items: center;
  }

  .social-section p:last-child {
    margin-bottom: 0;
    color: var(--color-navy-800);
  }

  @media (max-width: 900px) {
    .forms-grid,
    .social-section {
      grid-template-columns: 1fr;
    }
  }
</style>

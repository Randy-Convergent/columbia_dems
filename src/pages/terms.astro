---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
---

<Layout title="Terms & Conditions" description="Terms and Conditions for Columbia County Democrats.">
  <Section background="white">
    <h1>Terms &amp; Conditions</h1>
    <div class="prose">
      <p>
        By using this website, you agree to use it lawfully and respectfully. Content on this site
        — including text, photos, and graphics — belongs to Columbia County Democrats unless
        otherwise noted, and may not be used for commercial purposes without permission.
      </p>
      <p>
        Links to external websites (such as government voter registration or election-results
        sites) are provided for convenience. We aren't responsible for the content or availability
        of those third-party sites.
      </p>
      <p><em>This is placeholder policy language for a demo site and should be reviewed before launch.</em></p>
    </div>
  </Section>
</Layout>

<style>
  .prose {
    max-width: 44rem;
    color: var(--color-ink-soft);
  }
</style>

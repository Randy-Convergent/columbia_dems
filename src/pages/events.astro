---
import { getCollection, render } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import EventCard from '../components/EventCard.astro';
import { Image } from 'astro:assets';
import scappooseTotemPole from '../assets/images/scappoose-totem-pole.jpg';

const allEvents = await getCollection('events');
const now = new Date();

const recurring = allEvents.filter((e) => e.data.recurring);
const dated = allEvents
  .filter((e) => !e.data.recurring && e.data.date)
  .sort((a, b) => (a.data.date?.getTime() ?? 0) - (b.data.date?.getTime() ?? 0));

const upcomingDated = dated.filter((e) => (e.data.date as Date) >= now);
const pastDated = dated.filter((e) => (e.data.date as Date) < now);

async function withContent(entries: typeof allEvents) {
  return Promise.all(
    entries.map(async (event) => ({ event, Content: (await render(event)).Content }))
  );
}

const recurringRendered = await withContent(recurring);
const upcomingRendered = await withContent(upcomingDated);
const pastRendered = await withContent(pastDated);
---

<Layout title="Events" description="Upcoming meetings, protests, and events from Columbia County Democrats.">
  <Section background="navy" tight>
    <p class="eyebrow" style="color: var(--color-gold-400);">Show up with us</p>
    <h1>Events</h1>
    <p class="lede">From monthly meetings to community protests, here's where to find us.</p>
  </Section>

  <Section background="white">
    <h2>Recurring</h2>
    <div class="events-grid">
      {recurringRendered.map(({ event, Content }) => (
        <EventCard
          title={event.data.title}
          time={event.data.time}
          location={event.data.location}
          recurring={true}
        >
          <Content />
        </EventCard>
      ))}
      <div class="photo-card">
        <Image
          src={scappooseTotemPole}
          alt="The welcome sign and totem pole in Scappoose, Oregon"
          width={320}
          height={569}
          class="photo-card-img"
        />
        <p class="photo-card-caption">
          Our monthly protest rotates between Safeway and this totem pole in Scappoose.
        </p>
      </div>
    </div>
  </Section>

  {upcomingRendered.length > 0 && (
    <Section background="soft">
      <h2>Upcoming</h2>
      <div class="events-grid">
        {upcomingRendered.map(({ event, Content }) => (
          <EventCard
            title={event.data.title}
            date={event.data.date}
            time={event.data.time}
            location={event.data.location}
            sample={event.data.sample}
          >
            <Content />
          </EventCard>
        ))}
      </div>
    </Section>
  )}

  {pastRendered.length > 0 && (
    <Section background="white">
      <h2>Past events</h2>
      <div class="events-grid">
        {pastRendered.map(({ event, Content }) => (
          <EventCard
            title={event.data.title}
            date={event.data.date}
            time={event.data.time}
            location={event.data.location}
            sample={event.data.sample}
          >
            <Content />
          </EventCard>
        ))}
      </div>
    </Section>
  )}
</Layout>

<style>
  .lede {
    color: rgba(255, 255, 255, 0.85);
    font-size: 1.1rem;
  }

  .events-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.75rem;
    margin-top: 2rem;
  }

  .photo-card {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    box-shadow: var(--shadow-card);
  }

  .photo-card-img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-md);
  }

  .photo-card-caption {
    margin: 0.75rem 0 0;
    color: var(--color-ink-soft);
    font-size: 0.9rem;
  }

  @media (max-width: 900px) {
    .events-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

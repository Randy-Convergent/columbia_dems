---
import { Image } from 'astro:assets';

interface Props {
  name: string;
  office: string;
  photo?: string;
  website?: string;
  sample?: boolean;
}

const { name, office, photo, website, sample = false } = Astro.props;

const images = import.meta.glob<{ default: ImageMetadata }>('../assets/images/*.jpg', { eager: true });
const photoModule = photo ? images[`../assets/images/${photo}`] : undefined;

const initials = name
  .split(' ')
  .map((part) => part[0])
  .join('');
---

<article class="candidate-card">
  {sample && <p class="badge">Sample content — replace before launch</p>}
  <div class="header">
    {photoModule ? (
      <Image src={photoModule.default} alt={name} width={120} height={120} class="photo" />
    ) : (
      <div class="photo placeholder" aria-hidden="true">{initials}</div>
    )}
    <div>
      <h3>{name}</h3>
      <p class="office">{office}</p>
    </div>
  </div>
  <div class="body">
    <slot />
  </div>
  {website && (
    <a class="website-link" href={website} target="_blank" rel="noopener noreferrer">Campaign website →</a>
  )}
</article>

<style>
  .candidate-card {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    box-shadow: var(--shadow-card);
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .badge {
    display: inline-block;
    background: var(--color-gold-400);
    color: var(--color-navy-950);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
    margin-bottom: 1rem;
    align-self: flex-start;
  }

  .header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .photo {
    width: 4.5rem;
    height: 4.5rem;
    flex-shrink: 0;
    object-fit: cover;
    border-radius: 999px;
  }

  .photo.placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-blue-100);
    color: var(--color-navy-800);
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
  }

  h3 {
    margin-bottom: 0.15rem;
  }

  .office {
    color: var(--color-red-600);
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.78rem;
    letter-spacing: 0.05em;
    margin: 0;
  }

  .body {
    color: var(--color-ink-soft);
    font-size: 0.95rem;
    flex-grow: 1;
  }

  .body :global(p:last-child) {
    margin-bottom: 0;
  }

  .website-link {
    display: inline-block;
    margin-top: 1rem;
    color: var(--color-blue-600);
    font-weight: 700;
    text-decoration: none;
  }

  .website-link:hover {
    text-decoration: underline;
  }
</style>

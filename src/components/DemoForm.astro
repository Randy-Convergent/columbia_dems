---
interface Props {
  id: string;
  submitLabel: string;
  successMessage?: string;
}

const {
  id,
  submitLabel,
  successMessage = "Thanks! This is a demo site, so this form isn't wired up yet — no message was actually sent.",
} = Astro.props;
---

<form data-demo-form id={id} class="demo-form" novalidate>
  <div class="fields">
    <slot />
  </div>
  <button type="submit" class="submit-btn">{submitLabel}</button>
</form>
<p class="form-success" role="status" hidden>{successMessage}</p>

<style>
  .demo-form {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .demo-form :global(label) {
    display: block;
    font-weight: 600;
    margin-bottom: 0.35rem;
    color: var(--color-navy-900);
  }

  .demo-form :global(input),
  .demo-form :global(select),
  .demo-form :global(textarea) {
    width: 100%;
    padding: 0.75rem 0.9rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font: inherit;
    background: white;
  }

  .demo-form :global(input:focus),
  .demo-form :global(select:focus),
  .demo-form :global(textarea:focus) {
    outline: 2px solid var(--color-blue-500);
    outline-offset: 1px;
  }

  .submit-btn {
    align-self: flex-start;
    background: var(--color-blue-600);
    color: white;
    border: none;
    padding: 0.85rem 1.75rem;
    border-radius: 999px;
    font-weight: 700;
    font-size: 1rem;
    cursor: pointer;
    transition: background-color 0.15s ease, transform 0.15s ease;
  }

  .submit-btn:hover {
    background: var(--color-navy-800);
    transform: translateY(-2px);
  }

  .form-success {
    background: var(--color-blue-100);
    color: var(--color-navy-900);
    border-radius: var(--radius-md);
    padding: 1rem 1.25rem;
    font-weight: 600;
  }
</style>

<script>
  document.querySelectorAll<HTMLFormElement>('[data-demo-form]').forEach((form) => {
    form.addEventListener('submit', (event) => {
      event.preventDefault();
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }
      const success = form.nextElementSibling as HTMLElement | null;
      form.hidden = true;
      if (success) success.hidden = false;
    });
  });
</script>

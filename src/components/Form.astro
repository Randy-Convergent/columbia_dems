---
interface Props {
  id: string;
  action: string;
  submitLabel: string;
  successMessage?: string;
  errorMessage?: string;
}

const {
  id,
  action,
  submitLabel,
  successMessage = "Thanks! We've received your message and will be in touch soon.",
  errorMessage = "Something went wrong sending that — please try again, or email us directly.",
} = Astro.props;
---

<form data-form id={id} class="demo-form" action={action} method="POST" novalidate>
  <div class="fields">
    <slot />
  </div>
  <input type="text" name="_gotcha" class="hp-field" tabindex="-1" autocomplete="off" aria-hidden="true" />
  <button type="submit" class="submit-btn">{submitLabel}</button>
</form>
<p class="form-success" role="status" hidden>{successMessage}</p>
<p class="form-error" role="alert" hidden>{errorMessage}</p>

<style>
  .demo-form {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .hp-field {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .demo-form :global(label) {
    display: block;
    font-weight: 600;
    margin-bottom: 0.35rem;
    color: var(--color-navy-900);
  }

  .demo-form :global(input),
  .demo-form :global(select),
  .demo-form :global(textarea) {
    width: 100%;
    padding: 0.75rem 0.9rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font: inherit;
    background: white;
  }

  .demo-form :global(input:focus),
  .demo-form :global(select:focus),
  .demo-form :global(textarea:focus) {
    outline: 2px solid var(--color-blue-500);
    outline-offset: 1px;
  }

  .submit-btn {
    align-self: flex-start;
    background: var(--color-blue-600);
    color: white;
    border: none;
    padding: 0.85rem 1.75rem;
    border-radius: 999px;
    font-weight: 700;
    font-size: 1rem;
    cursor: pointer;
    transition: background-color 0.15s ease, transform 0.15s ease;
  }

  .submit-btn:hover {
    background: var(--color-navy-800);
    transform: translateY(-2px);
  }

  .submit-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  .form-success {
    background: var(--color-blue-100);
    color: var(--color-navy-900);
    border-radius: var(--radius-md);
    padding: 1rem 1.25rem;
    font-weight: 600;
  }

  .form-error {
    background: #fdecee;
    color: var(--color-red-600);
    border-radius: var(--radius-md);
    padding: 1rem 1.25rem;
    font-weight: 600;
  }
</style>

<script>
  document.querySelectorAll<HTMLFormElement>('[data-form]').forEach((form) => {
    const submitBtn = form.querySelector<HTMLButtonElement>('.submit-btn');
    const success = form.nextElementSibling as HTMLElement | null;
    const error = success?.nextElementSibling as HTMLElement | null;

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }

      if (error) error.hidden = true;
      if (submitBtn) submitBtn.disabled = true;

      try {
        const response = await fetch(form.action, { method: 'POST', body: new FormData(form) });
        if (!response.ok) throw new Error(`Request failed: ${response.status}`);
        form.hidden = true;
        if (success) success.hidden = false;
      } catch {
        if (error) error.hidden = false;
      } finally {
        if (submitBtn) submitBtn.disabled = false;
      }
    });
  });
</script>

---
import { CONTACT, NAV_LINKS } from '../consts';
import SocialLinks from './SocialLinks.astro';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container grid">
    <div>
      <p class="wordmark">Columbia County <strong>Democrats</strong></p>
      <p class="tagline">Empowering Democratic voices in Columbia County, Oregon.</p>
      <p class="follow-label">Follow us for meeting times &amp; updates</p>
      <SocialLinks size={22} />
    </div>

    <div>
      <h2>Explore</h2>
      <ul>
        {NAV_LINKS.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <h2>Contact</h2>
      <ul>
        <li><a href={CONTACT.phoneHref}>{CONTACT.phone}</a></li>
        <li><a href={`mailto:${CONTACT.email}`}>{CONTACT.email}</a></li>
        <li>Columbia County, Oregon</li>
      </ul>
    </div>
  </div>

  <div class="container legal">
    <p>&copy; {year} Columbia County Democrats. Paid for by Columbia County Democrats.</p>
    <ul>
      <li><a href="/privacy">Privacy Policy</a></li>
      <li><a href="/terms">Terms &amp; Conditions</a></li>
      <li><a href="/accessibility">Accessibility Statement</a></li>
    </ul>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-navy-950);
    color: rgba(255, 255, 255, 0.85);
    padding-block: 3.5rem 1.5rem;
  }

  .grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 2.5rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }

  .wordmark {
    font-family: var(--font-display);
    font-size: 1.15rem;
    color: white;
    margin-bottom: 0.5rem;
  }

  .wordmark strong {
    color: var(--color-gold-400);
  }

  .tagline {
    max-width: 30ch;
    color: rgba(255, 255, 255, 0.7);
  }

  .follow-label {
    font-size: 0.85rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.75);
    margin-bottom: 0.75rem;
  }

  h2 {
    color: white;
    font-family: var(--font-body);
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  ul a {
    color: rgba(255, 255, 255, 0.75);
    text-decoration: none;
  }

  ul a:hover {
    color: white;
  }

  .legal {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 1.5rem;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.55);
  }

  .legal ul {
    flex-direction: row;
    gap: 1.25rem;
  }

  @media (max-width: 720px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
